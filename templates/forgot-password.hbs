<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reset Your Password</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background-color: #f4f6f9; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #1a1a2e; }
    .wrapper { max-width: 600px; margin: 40px auto; padding: 0 16px; }
    .card { background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
    .header { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); padding: 36px 40px; text-align: center; }
    .header-logo { font-size: 22px; font-weight: 700; color: #e94560; letter-spacing: 0.5px; }
    .header-logo span { color: #ffffff; }
    .body { padding: 40px; }
    .greeting { font-size: 18px; font-weight: 600; color: #1a1a2e; margin-bottom: 16px; }
    .text { font-size: 15px; line-height: 1.7; color: #4a5568; margin-bottom: 20px; }
    .btn-container { text-align: center; margin: 32px 0; }
    .btn { display: inline-block; background: #e94560; color: #ffffff !important; text-decoration: none; padding: 14px 36px; border-radius: 8px; font-size: 15px; font-weight: 600; letter-spacing: 0.3px; }
    .token-box { background: #f7fafc; border: 1px dashed #cbd5e0; border-radius: 8px; padding: 16px 20px; margin: 24px 0; }
    .token-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: #718096; margin-bottom: 8px; }
    .token-value { font-family: 'Courier New', Courier, monospace; font-size: 13px; color: #2d3748; word-break: break-all; line-height: 1.6; }
    .expiry-badge { display: inline-block; background: #fff5f5; color: #c53030; border: 1px solid #fed7d7; border-radius: 6px; padding: 6px 12px; font-size: 13px; font-weight: 500; margin-bottom: 24px; }
    .divider { height: 1px; background: #e2e8f0; margin: 28px 0; }
    .warning { font-size: 13px; color: #718096; line-height: 1.6; }
    .footer { background: #f7fafc; padding: 24px 40px; text-align: center; border-top: 1px solid #e2e8f0; }
    .footer-text { font-size: 12px; color: #a0aec0; line-height: 1.6; }
    @media (max-width: 480px) {
      .body { padding: 28px 24px; }
      .footer { padding: 20px 24px; }
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="header">
        <div class="header-logo">Electro<span>Pi</span> <span style="color:#a0aec0;font-weight:400;font-size:16px;">PM</span></div>
      </div>
      <div class="body">
        <p class="greeting">Hi {{name}},</p>
        <p class="text">We received a request to reset the password for your account associated with <strong>{{email}}</strong>. If you made this request, click the button below to set a new password.</p>

        <div class="btn-container">
          <a href="{{resetUrl}}" class="btn">Reset My Password</a>
        </div>

        <p class="text" style="text-align:center;font-size:13px;color:#718096;">Or paste this link into your browser:</p>
        <p style="text-align:center;font-size:12px;word-break:break-all;color:#4a90e2;margin-bottom:24px;">{{resetUrl}}</p>

        <div class="token-box">
          <div class="token-label">Reset Token (for API / Postman use)</div>
          <div class="token-value">{{token}}</div>
        </div>

        <div class="expiry-badge">⏱ This link and token expire in {{expiresInMinutes}} minutes</div>

        <div class="divider"></div>

        <p class="warning">
          If you did not request a password reset, you can safely ignore this email — your password will remain unchanged.<br><br>
          For security, this link can only be used once.
        </p>
      </div>
      <div class="footer">
        <p class="footer-text">
          This email was sent by <strong>ElectroPi Project Management</strong><br>
          You're receiving this because a password reset was requested for your account.
        </p>
      </div>
    </div>
  </div>
</body>
</html>
